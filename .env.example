# 环境变量示例文件
# 复制此文件为 .env.local 并填写实际值
# 注意：.env.local 文件不应提交到版本控制

# ============================================================================
# Supabase 数据库配置
# ============================================================================
# ⚠️ 重要：在 Coze 平台环境中，以下变量会自动注入，无需手动配置
# 以下配置仅用于本地开发环境

# Supabase 项目 URL
COZE_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_URL=

# Supabase 匿名访问密钥
COZE_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase 服务端密钥（可选，拥有更高权限）
COZE_SUPABASE_SERVICE_ROLE_KEY=

# ============================================================================
# 应用配置
# ============================================================================

# 应用环境（由 Coze 平台自动注入）
# 开发环境: DEV
# 生产环境: PROD
COZE_PROJECT_ENV=DEV

# 项目工作目录（由 Coze 平台自动注入）
COZE_WORKSPACE_PATH=/workspace/projects

# 对外访问域名（由 Coze 平台自动注入）
COZE_PROJECT_DOMAIN_DEFAULT=https://your-project.dev.coze.site

# 服务监听端口（由 Coze 平台自动注入）
DEPLOY_RUN_PORT=5000

# ============================================================================
# 对象存储配置（可选）
# ============================================================================

# S3 兼容对象存储配置
# 如果使用外部对象存储，请填写以下配置

# S3 存储桶名称
S3_BUCKET_NAME=

# S3 访问密钥
S3_ACCESS_KEY_ID=

# S3 密钥
S3_SECRET_ACCESS_KEY=

# S3 区域
S3_REGION=

# S3 端点
S3_ENDPOINT=

# ============================================================================
# 其他配置（可选）
# ============================================================================

# 应用名称
NEXT_PUBLIC_APP_NAME=室内设计工作室管理系统

# 应用版本
NEXT_PUBLIC_APP_VERSION=1.0.0

# API 基础路径
NEXT_PUBLIC_API_BASE_URL=/api

# 启用调试模式
NEXT_PUBLIC_DEBUG=false

# ============================================================================
# 配置说明
# ============================================================================

# 1. 环境变量优先级：
#    - Coze 平台注入的环境变量 > .env.local 中的配置
#
# 2. 公开变量 vs 私有变量：
#    - NEXT_PUBLIC_* 前缀的变量会在浏览器端可见
#    - 不带前缀的变量仅在服务端可见
#
# 3. Supabase 配置：
#    - 在 Coze 平台：环境变量自动注入，无需配置
#    - 本地开发：复制此文件为 .env.local 并填写 Supabase 凭证
#
# 4. 如何获取 Supabase 凭证：
#    1) 访问 https://supabase.com
#    2) 创建新项目或选择现有项目
#    3) 进入 Settings > API
#    4) 复制 Project URL 和 anon public key
#
# 5. 安全注意事项：
#    - 永远不要将 .env.local 提交到 Git
#    - 生产环境使用 Service Role Key 时，确保仅在服务端使用
#    - 定期轮换密钥
